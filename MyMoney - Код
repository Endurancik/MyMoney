    def compareMonths(self):
        self.cur.execute("""
            SELECT
                SUM(CASE WHEN t='expense' AND d >= date('now','start of month') THEN am ELSE 0 END),
                SUM(CASE WHEN t='expense' AND d >= date('now','-1 month','start of month')
                         AND d < date('now','start of month') THEN am ELSE 0 END)
            FROM items
        """)
        row = self.cur.fetchone()
        thisMonth = row[0] or 0
        lastMonth = row[1] or 0
        if lastMonth > 0:
            diff = (thisMonth - lastMonth) / lastMonth * 100
            trend = "📈 Рост" if diff > 0 else "📉 Снижение"
            msg = (f"Этот месяц: {thisMonth:.0f} ₽\n"
                   f"Прошлый месяц: {lastMonth:.0f} ₽\n\n"
                   f"{trend} на {abs(diff):.1f}%")
        else:
