    def checkReminders(self):
        while self.running:
            try:
                now = datetime.now().strftime("%Y-%m-%d %H:%M")
                for reminder in self.reminders:
                    if reminder[0][:16] == now:
                        msg = reminder[1]
                        self.root.after(0, lambda m=msg: messagebox.showinfo("⏰ Напоминание", m))
                        self.cur.execute("UPDATE napom SET sdelano=1 WHERE d=?", (reminder[0],))
                        self.db.commit()
                time.sleep(30)
            except:
                pass

