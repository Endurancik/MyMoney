    def exportCsv(self):
        try:
            path = filedialog.asksaveasfilename(defaultextension=".csv",
                                                filetypes=[("CSV", "*.csv")])
            if not path:
                return
            with open(path, 'w', newline='', encoding='utf-8') as f:
                w = csv.writer(f)
                w.writerow(['Дата', 'Тип', 'Категория', 'Сумма', 'Описание'])
                self.cur.execute("SELECT d, t, cat, am, txt FROM items ORDER BY d DESC")
                w.writerows(self.cur.fetchall())
            messagebox.showinfo("Готово", "Файл сохранён")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

    def importCsv(self):
        try:
            path = filedialog.askopenfilename(filetypes=[("CSV", "*.csv")])
            if not path:
                return
            count = 0
            with open(path, 'r', encoding='utf-8') as f:
                for row in csv.reader(f):
                    if len(row) >= 4:
                        try:
                            d, t, cat, am = row[:4]
                            txt = row[4] if len(row) > 4 else ""
                            self.cur.execute(
                                "INSERT INTO items (d, t, cat, am, txt) VALUES (?, ?, ?, ?, ?)",
                                (d, t, cat, float(am), txt))
                            count += 1
                        except:
                            continue
            self.db.commit()
            self.reloadHistory()
            self.updateStats()
            messagebox.showinfo("Готово", f"Импортировано: {count} записей")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

