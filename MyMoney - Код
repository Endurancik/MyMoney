    def refreshCategories(self):
        t = self.typeVar.get()
        self.cur.execute("SELECT name FROM cats WHERE typ=? ORDER BY name", (t,))
        cats = [r[0] for r in self.cur.fetchall()]
        self.catCombo['values'] = cats
        if cats:
            self.catVar.set(cats[0])

    def refreshLimitCategories(self):
        self.cur.execute("SELECT name FROM cats WHERE typ='expense' ORDER BY name")
        cats = [r[0] for r in self.cur.fetchall()]
        self.limitCatCombo['values'] = cats
        if cats:
            self.limitCatCombo.set(cats[0])

    def reloadHistory(self):
        for row in self.table.get_children():
            self.table.delete(row)
        self.cur.execute(
            "SELECT id, d, t, cat, am, txt FROM items ORDER BY d DESC, id DESC LIMIT 300")
        for row in self.cur.fetchall():
            iid, d, t, cat, am, txt = row
            if t == "income":
                label, amStr, tag = "Доход", f"+{am:.2f}", "income"
            else:
                label, amStr, tag = "Расход", f"-{am:.2f}", "expense"
            self.table.insert("", "end", values=(iid, d, label, cat, amStr, txt or "-"), tags=(tag,))

    def filterHistory(self):
        for row in self.table.get_children():
            self.table.delete(row)
        dFrom = self.filterFrom.get_date().strftime("%Y-%m-%d")
        dTo = self.filterTo.get_date().strftime("%Y-%m-%d")
        self.cur.execute(
            "SELECT id, d, t, cat, am, txt FROM items WHERE d BETWEEN ? AND ? ORDER BY d DESC",
            (dFrom, dTo))
        for row in self.cur.fetchall():
            iid, d, t, cat, am, txt = row
            if t == "income":
                label, amStr, tag = "Доход", f"+{am:.2f}", "income"
            else:
                label, amStr, tag = "Расход", f"-{am:.2f}", "expense"
            self.table.insert("", "end", values=(iid, d, label, cat, amStr, txt or "-"), tags=(tag,))

    def updateStats(self):
        try:
            self.cur.execute("SELECT SUM(am) FROM items WHERE t='income'")
            inc = self.cur.fetchone()[0] or 0
            self.cur.execute("SELECT SUM(am) FROM items WHERE t='expense'")
            exp = self.cur.fetchone()[0] or 0
            self.totalIncomeVar.set(f"{inc:.2f} ₽")
            self.totalExpenseVar.set(f"{exp:.2f} ₽")
            self.balanceVar.set(f"{inc - exp:.2f} ₽")

            today = date.today()
            daysLeft = calendar.monthrange(today.year, today.month)[1] - today.day
            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='income' AND d >= date('now','start of month')")
            monthInc = self.cur.fetchone()[0] or 0
            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='expense' AND d >= date('now','start of month')")
            monthExp = self.cur.fetchone()[0] or 0
            self.monthInfoVar.set(
                f"До конца месяца: {daysLeft} дн. | Остаток: {monthInc - monthExp:.0f} ₽")
        except:
            pass

    def saveEntry(self):
        try:
            t = self.typeVar.get()
            amountStr = self.amountVar.get()
            cat = self.catVar.get()
            desc = self.descVar.get()
            d = self.dateEntry.get_date().strftime("%Y-%m-%d")

            if not amountStr:
                messagebox.showerror("Ошибка", "Введите сумму")
                return
            amount = float(amountStr)
            if amount <= 0:
                messagebox.showerror("Ошибка", "Сумма должна быть больше нуля")
                return
            if not cat:
                messagebox.showerror("Ошибка", "Выберите категорию")
                return

            if t == "expense":
                self.cur.execute("SELECT am FROM lims WHERE cat=?", (cat,))
                limit = self.cur.fetchone()
                if limit:
                    self.cur.execute(
                        "SELECT SUM(am) FROM items WHERE cat=? AND t='expense'"
                        " AND d >= date('now','start of month')", (cat,))
                    spent = self.cur.fetchone()[0] or 0
                    if spent + amount > limit[0]:
                        if not messagebox.askyesno("Превышение лимита",
                                                   f"Категория: {cat}\n"
                                                   f"Лимит: {limit[0]:.2f} ₽\n"
                                                   f"Потрачено: {spent:.2f} ₽\n\n"
                                                   f"Добавить всё равно?"):
                            return

            self.cur.execute(
                "INSERT INTO items (d, t, cat, am, txt) VALUES (?, ?, ?, ?, ?)",
                (d, t, cat, amount, desc))
            self.db.commit()
            self.reloadHistory()
            self.updateStats()
            self.amountVar.set("")
            self.descVar.set("")
            messagebox.showinfo("Готово", "Запись добавлена ✅")
        except Exception as e:
            messagebox.showerror("Ошибка", str(e))

