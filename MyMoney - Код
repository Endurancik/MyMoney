    def connectDb(self):
        if getattr(sys, 'frozen', False):
            baseDir = os.path.dirname(sys.executable)
        else:
            baseDir = os.path.dirname(os.path.abspath(__file__))
        path = os.path.join(baseDir, "money.db")
        self.db = sqlite3.connect(path, check_same_thread=False)
        self.db.execute("PRAGMA journal_mode=WAL")
        self.db.execute("PRAGMA synchronous=NORMAL")
        self.cur = self.db.cursor()
        self.cur.executescript("""
            CREATE TABLE IF NOT EXISTS items (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                d TEXT NOT NULL, t TEXT NOT NULL, cat TEXT NOT NULL,
                am REAL NOT NULL, txt TEXT
            );
            CREATE TABLE IF NOT EXISTS cats (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL, typ TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS lims (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                cat TEXT NOT NULL, am REAL NOT NULL, per TEXT DEFAULT "month"
            );
            CREATE TABLE IF NOT EXISTS dolg (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL, typ TEXT NOT NULL, am REAL NOT NULL,
                d TEXT, komment TEXT
            );
            CREATE TABLE IF NOT EXISTS cel (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL, am REAL NOT NULL, nakopleno REAL DEFAULT 0,
                d TEXT, prior INTEGER DEFAULT 1
            );
            CREATE TABLE IF NOT EXISTS napom (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                d TEXT NOT NULL, txt TEXT NOT NULL, sdelano INTEGER DEFAULT 0
            );
            CREATE TABLE IF NOT EXISTS recurring (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL, t TEXT NOT NULL, cat TEXT NOT NULL,
                am REAL NOT NULL, day_of_month INTEGER NOT NULL,
                last_added TEXT, active INTEGER DEFAULT 1
            );
            CREATE TABLE IF NOT EXISTS budget (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                month TEXT NOT NULL,
                planned_income REAL DEFAULT 0,
                planned_expense REAL DEFAULT 0
            );
            CREATE INDEX IF NOT EXISTS idx_d ON items(d);
            CREATE INDEX IF NOT EXISTS idx_t ON items(t);
        """)
        self.cur.execute("SELECT COUNT(*) FROM cats")
        if self.cur.fetchone()[0] == 0:
            for c in ["Зарплата", "Подарки", "Инвестиции", "Другое"]:
                self.cur.execute("INSERT INTO cats (name, typ) VALUES (?, 'income')", (c,))
            for c in ["Продукты", "Транспорт", "Жилье", "Развлечения", "Здоровье", "Одежда", "Другое"]:
                self.cur.execute("INSERT INTO cats (name, typ) VALUES (?, 'expense')", (c,))
        self.db.commit()

