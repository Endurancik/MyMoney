    def validateNumber(self, text):
        if text in ("", "."):
            return True
        try:
            float(text)
            return text.count('.') <= 1
        except:
            return False

    def autofillCategory(self, event=None):
        desc = self.descVar.get().lower()
        if not desc:
            return
        typ = self.typeVar.get()
        keywords = incomeKeywords if typ == "income" else expenseKeywords
        for pattern, cat in keywords.items():
            if re.search(pattern, desc, re.IGNORECASE):
                self.cur.execute("SELECT name FROM cats WHERE typ=? AND name=?", (typ, cat))
                if self.cur.fetchone():
                    self.catVar.set(cat)
                    return

    def quickAdd(self):
        raw = self.quickVar.get().strip()
        if not raw:
            return

        parts = raw.rsplit(None, 1)
        if len(parts) < 2:
            messagebox.showerror("Ошибка", 'Напишите описание и сумму через пробел\nНапример: кофе 150')
            return

        desc, amountStr = parts
        try:
            amount = float(amountStr.replace(',', '.'))
        except ValueError:
            messagebox.showerror("Ошибка", f'Не могу распознать сумму: "{amountStr}"')
            return

        if amount <= 0:
            messagebox.showerror("Ошибка", "Сумма должна быть больше нуля")
            return

        typ, cat = guessType(desc)

        # Если категория не распознана — используем выбор пользователя
        if cat == "Другое":
            typ = self.quickTypeVar.get()

        found = self.cur.execute("SELECT name FROM cats WHERE typ=? AND name=?", (typ, cat)).fetchone()
        if not found:
            fallback = self.cur.execute("SELECT name FROM cats WHERE typ=? LIMIT 1", (typ,)).fetchone()
            cat = fallback[0] if fallback else "Другое"

        today = date.today().strftime("%Y-%m-%d")
        self.cur.execute("INSERT INTO items (d, t, cat, am, txt) VALUES (?, ?, ?, ?, ?)",
                         (today, typ, cat, amount, desc))
        self.db.commit()
        self.quickVar.set("")
        self.reloadHistory()
        self.updateStats()

        label = "Доход" if typ == "income" else "Расход"
        messagebox.showinfo("Готово", f"✅ {label}: {desc}\n{amount:.2f} ₽ → {cat}")

