class SimpleDateEntry(tk.Frame):
    def __init__(self, parent, width=12, date_pattern='yyyy-mm-dd', **kwargs):
        super().__init__(parent, **kwargs)
        self.var = tk.StringVar(value=date.today().strftime("%Y-%m-%d"))
        tk.Entry(self, textvariable=self.var, width=width).pack()

    def getDate(self):
        try:
            return datetime.strptime(self.var.get(), "%Y-%m-%d").date()
        except:
            return date.today()

    def setDate(self, d):
        self.var.set(d if isinstance(d, str) else d.strftime("%Y-%m-%d"))

    def get(self):
        return self.var.get()

    def get_date(self):
        return self.getDate()

    def set_date(self, d):
        self.setDate(d)


if not hasCalendar:
    DateEntry = SimpleDateEntry


incomeKeywords = {
    r'зарплата|аванс|премия|получил|выплата': 'Зарплата',
    r'подарок|подарили': 'Подарки',
    r'дивиденд|инвестиц|процент': 'Инвестиции',
}

expenseKeywords = {
    r'такси|убер|каршеринг': 'Транспорт',
    r'метро|автобус|трамвай|маршрутка|электричка': 'Транспорт',
    r'кофе|кафе|ресторан|обед|ужин|завтрак|пицца|суши|бургер|столовая': 'Развлечения',
    r'продукт|магазин|пятёрочка|перекрёсток|ашан|лента|дикси|вкусвилл|супермаркет': 'Продукты',
    r'аренда|квартира|жильё|коммунал|жкх|электричество|газ|вода': 'Жилье',
    r'кино|театр|концерт|музей|парк|игра|подписка|netflix|spotify': 'Развлечения',
    r'аптека|лекарств|врач|клиника|больниц': 'Здоровье',
    r'одежда|обувь|куртка|джинсы|платье': 'Одежда',
}


def guessType(text):
    txt = text.lower()
    for pattern, cat in incomeKeywords.items():
        if re.search(pattern, txt, re.IGNORECASE):
            return "income", cat
    for pattern, cat in expenseKeywords.items():
        if re.search(pattern, txt, re.IGNORECASE):
            return "expense", cat
    return "expense", "Другое"


