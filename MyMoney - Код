    def applyRecurring(self):
        today = date.today()
        monthKey = today.strftime("%Y-%m")
        self.cur.execute(
            "SELECT id, name, t, cat, am, day_of_month, last_added FROM recurring WHERE active=1")
        for row in self.cur.fetchall():
            rid, name, t, cat, am, dom, last = row
            if last and last.startswith(monthKey):
                continue
            if today.day >= dom:
                payDate = f"{monthKey}-{dom:02d}"
                self.cur.execute(
                    "INSERT INTO items (d, t, cat, am, txt) VALUES (?, ?, ?, ?, ?)",
                    (payDate, t, cat, am, f"[Авто] {name}"))
                self.cur.execute("UPDATE recurring SET last_added=? WHERE id=?",
                                 (today.strftime("%Y-%m-%d"), rid))
        self.db.commit()

    def showBudget(self):
        win = tk.Toplevel(self.root)
        win.title("📊 Бюджет месяца")
        win.geometry("570x520")

        today = date.today()
        monthKey = today.strftime("%Y-%m")
        monthName = f"{self.months[today.month]} {today.year}"

        tk.Label(win, text=f"Бюджет на {monthName}",
                 font=("Arial", 14, "bold")).pack(pady=10)

        self.cur.execute(
            "SELECT planned_income, planned_expense FROM budget WHERE month=?", (monthKey,))
        saved = self.cur.fetchone()
        planInc = saved[0] if saved else 0
        planExp = saved[1] if saved else 0

        form = tk.Frame(win)
        form.pack(padx=20, pady=5)

        tk.Label(form, text="Плановый доход (₽):").grid(row=0, column=0, sticky=tk.W, pady=4)
        planIncVar = tk.StringVar(value=str(planInc))
        tk.Entry(form, textvariable=planIncVar, width=18).grid(row=0, column=1)

        tk.Label(form, text="Плановые расходы (₽):").grid(row=1, column=0, sticky=tk.W, pady=4)
        planExpVar = tk.StringVar(value=str(planExp))
        tk.Entry(form, textvariable=planExpVar, width=18).grid(row=1, column=1)

        infoFrame = tk.Frame(win, bg="#f5f5f5", relief=tk.GROOVE, bd=1)
        infoFrame.pack(fill=tk.X, padx=15, pady=10)

        def refresh(pi, pe):
            for w in infoFrame.winfo_children():
                w.destroy()
            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='income' AND d >= date('now','start of month')")
            factInc = self.cur.fetchone()[0] or 0
            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='expense' AND d >= date('now','start of month')")
            factExp = self.cur.fetchone()[0] or 0

            tableRows = [
                ("", "План", "Факт", "Разница"),
                ("Доходы",  f"{pi:.0f}", f"{factInc:.0f}", f"{pi - factInc:+.0f}"),
                ("Расходы", f"{pe:.0f}", f"{factExp:.0f}", f"{pe - factExp:+.0f}"),
                ("Баланс",  f"{pi - pe:.0f}", f"{factInc - factExp:.0f}",
                 f"{(factInc - factExp) - (pi - pe):+.0f}"),
            ]

            for i, row in enumerate(tableRows):
                for j, val in enumerate(row):
                    bg = "#ECEFF1" if i == 0 else "white"
                    font = ("Arial", 9, "bold") if i == 0 else ("Arial", 9)
                    tk.Label(infoFrame, text=val, bg=bg, font=font,
                             width=14, relief=tk.RIDGE, pady=4).grid(
                        row=i, column=j, sticky=tk.NSEW)

            if pi > 0:
                pct = min(factInc / pi * 100, 100)
                tk.Label(infoFrame, text=f"Доходы: {pct:.0f}%", bg="white",
                         font=("Arial", 8)).grid(row=4, column=0, columnspan=4,
                                                 sticky=tk.W, padx=5, pady=(6, 0))
                ttk.Progressbar(infoFrame, maximum=100, value=pct, length=480).grid(
                    row=5, column=0, columnspan=4, padx=8, pady=2, sticky=tk.EW)

            if pe > 0:
                pct = min(factExp / pe * 100, 100)
                label = "⚠️ Перерасход!" if pct >= 100 else f"Расходы: {pct:.0f}%"
                tk.Label(infoFrame, text=label, bg="white",
                         font=("Arial", 8)).grid(row=6, column=0, columnspan=4, sticky=tk.W, padx=5)
                ttk.Progressbar(infoFrame, maximum=100, value=pct, length=480).grid(
                    row=7, column=0, columnspan=4, padx=8, pady=2, sticky=tk.EW)

        def saveBudget():
            try:
                pi = float(planIncVar.get())
                pe = float(planExpVar.get())
                self.cur.execute("DELETE FROM budget WHERE month=?", (monthKey,))
                self.cur.execute(
                    "INSERT INTO budget (month, planned_income, planned_expense) VALUES (?, ?, ?)",
                    (monthKey, pi, pe))
                self.db.commit()
                refresh(pi, pe)
                messagebox.showinfo("Готово", "Бюджет сохранён")
            except:
                messagebox.showerror("Ошибка", "Введите числа")

        tk.Button(form, text="💾 Сохранить бюджет", command=saveBudget,
                  bg="#3F51B5", fg="white").grid(row=2, columnspan=2, pady=8)
        refresh(planInc, planExp)

    def exportPdf(self):
        if not hasReportlab:
            messagebox.showerror("Нет reportlab",
                                 "Установите:\n  pip install reportlab\nИ перезапустите программу")
            return
        path = filedialog.asksaveasfilename(
            defaultextension=".pdf",
            filetypes=[("PDF", "*.pdf")],
            initialfile=f"report_{date.today().strftime('%Y_%m')}.pdf")
        if not path:
            return

        try:
            today = date.today()
            monthName = f"{self.months[today.month]} {today.year}"
            doc = SimpleDocTemplate(path, pagesize=A4,
                                    leftMargin=2 * cm, rightMargin=2 * cm,
                                    topMargin=2 * cm, bottomMargin=2 * cm)
            styles = getSampleStyleSheet()
            story = []

            titleStyle = ParagraphStyle('T', parent=styles['Title'], fontSize=22, spaceAfter=6)
            h1Style = ParagraphStyle('H', parent=styles['Heading1'], fontSize=14, spaceAfter=4)

            story.append(Paragraph("Финансовый отчёт", titleStyle))
            story.append(Paragraph(f"{monthName}  |  Дата создания: {today}", styles['Normal']))
            story.append(Spacer(1, 0.5 * cm))

            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='income' AND d >= date('now','start of month')")
            monthInc = self.cur.fetchone()[0] or 0
            self.cur.execute(
                "SELECT SUM(am) FROM items WHERE t='expense' AND d >= date('now','start of month')")
            monthExp = self.cur.fetchone()[0] or 0
            self.cur.execute("SELECT SUM(am) FROM items WHERE t='income'")
            allInc = self.cur.fetchone()[0] or 0
            self.cur.execute("SELECT SUM(am) FROM items WHERE t='expense'")
            allExp = self.cur.fetchone()[0] or 0

            story.append(Paragraph("Итоги месяца", h1Style))
            summary = [
                ["Показатель", "Этот месяц", "За всё время"],
                ["Доходы",  f"{monthInc:.2f} руб.", f"{allInc:.2f} руб."],
                ["Расходы", f"{monthExp:.2f} руб.", f"{allExp:.2f} руб."],
                ["Баланс",  f"{monthInc - monthExp:+.2f} руб.", f"{allInc - allExp:+.2f} руб."],
            ]
            tbl = Table(summary, colWidths=[5 * cm, 5 * cm, 5 * cm])
            tbl.setStyle(TableStyle([
                ('BACKGROUND', (0, 0), (-1, 0), colors.HexColor('#1565C0')),
                ('TEXTCOLOR', (0, 0), (-1, 0), colors.white),
                ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
                ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
                ('GRID', (0, 0), (-1, -1), 0.5, colors.grey),
                ('ROWBACKGROUNDS', (0, 1), (-1, -1), [colors.white, colors.HexColor('#EEF2FF')]),
